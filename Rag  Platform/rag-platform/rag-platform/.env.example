# ── LLM Backend ───────────────────────────────────────────────────────────────
# Options: ollama | huggingface | hf_local | openai
LLM_BACKEND=ollama

# Ollama model name (run: ollama pull mistral)
LLM_MODEL=mistral
OLLAMA_BASE_URL=http://localhost:11434

# HuggingFace Hub (LLM_BACKEND=huggingface)
# HF_API_TOKEN=hf_...
# LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# OpenAI / OpenAI-compatible (LLM_BACKEND=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1   # override for local servers (LM Studio, etc.)
# LLM_MODEL=gpt-4o-mini

# ── Embeddings ────────────────────────────────────────────────────────────────
# Options: sentence-transformers/all-MiniLM-L6-v2 | sentence-transformers/all-mpnet-base-v2 | BAAI/bge-small-en-v1.5
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu   # use "cuda" if NVIDIA GPU is available

# ── Vector Store ──────────────────────────────────────────────────────────────
CHROMA_PATH=./vectorstore_data

# ── Retrieval ─────────────────────────────────────────────────────────────────
RETRIEVAL_K=4
SEARCH_MODE=mmr   # similarity | mmr | hybrid

# ── Generation ────────────────────────────────────────────────────────────────
LLM_TEMPERATURE=0.1

# ── Evaluation ────────────────────────────────────────────────────────────────
EVAL_PASS_THRESHOLD=0.6

# ── API Server ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8001
RELOAD=false
